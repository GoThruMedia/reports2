- [ ] **Step 3: Create `internal/auth/handler.go`**

```go
package auth

import (
    "crypto/sha256"
    "encoding/hex"
    "encoding/json"
    "net/http"
    "os"
    "strings"
    "time"

    "gorm.io/gorm"
    "gothru-3d-api/internal/apierror"
    "gothru-3d-api/internal/email"
    "gothru-3d-api/internal/middleware"
    "gothru-3d-api/internal/models"
)

type Handler struct {
    db    *gorm.DB
    email *email.Service
}

func NewHandler(db *gorm.DB, emailSvc *email.Service) *Handler {
    return &Handler{db: db, email: emailSvc}
}

func writeJSON(w http.ResponseWriter, status int, v any) {
    w.Header().Set("Content-Type", "application/json")
    w.WriteHeader(status)
    json.NewEncoder(w).Encode(v)
}

func writeError(w http.ResponseWriter, status int, msg string) {
    writeJSON(w, status, map[string]string{"error": msg})
}

func writeServerError(w http.ResponseWriter, err error) {
    writeError(w, http.StatusInternalServerError, apierror.Sanitize(err))
}

func hashToken(raw string) string {
    h := sha256.Sum256([]byte(raw))
    return hex.EncodeToString(h[:])
}

// POST /v1/auth/register
func (h *Handler) Register(w http.ResponseWriter, r *http.Request) {
    var body struct {
        FullName string `json:"fullName"`
        Email    string `json:"email"`
        Password string `json:"password"`
    }
    if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
        writeError(w, http.StatusBadRequest, "invalid request body"); return
    }
    if body.FullName == "" || body.Email == "" || body.Password == "" {
        writeError(w, http.StatusBadRequest, "fullName, email, and password are required"); return
    }
    if !strings.Contains(body.Email, "@") || !strings.Contains(body.Email, ".") {
        writeError(w, http.StatusBadRequest, "invalid email format"); return
    }
    if len(body.Password) < 8 {
        writeError(w, http.StatusBadRequest, "password must be at least 8 characters"); return
    }
    var existing models.User
    if result := h.db.Where("email = ?", body.Email).First(&existing); result.Error == nil {
        writeError(w, http.StatusConflict, "email already registered"); return
    }
    hash, err := HashPassword(body.Password)
    if err != nil {
        writeServerError(w, err); return
    }
    user := models.User{Email: body.Email, PasswordHash: hash, Name: body.FullName}
    if err := h.db.Create(&user).Error; err != nil {
        writeServerError(w, err); return
    }
    rawToken, tokenHash := GenerateToken()
    ev := models.EmailVerification{
        UserID:    user.ID,
        TokenHash: tokenHash,
        ExpiresAt: time.Now().Add(24 * time.Hour),
    }
    if err := h.db.Create(&ev).Error; err != nil {
        writeServerError(w, err); return
    }
    verifyURL := os.Getenv("NEXT_PUBLIC_APP_URL") + "/verify-email?token=" + rawToken
    go h.email.SendVerificationEmail(user.Email, user.Name, verifyURL)
    tok, err := IssueToken(user.ID.String(), user.Email)
    if err != nil {
        writeServerError(w, err); return
    }
    writeJSON(w, http.StatusCreated, map[string]any{
        "userId": user.ID.String(), "email": user.Email, "name": user.Name,
        "emailVerified": false, "token": tok,
    })
}

// POST /v1/auth/login
func (h *Handler) Login(w http.ResponseWriter, r *http.Request) {
    var body struct {
        Email    string `json:"email"`
        Password string `json:"password"`
    }
    if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
        writeError(w, http.StatusBadRequest, "invalid request body"); return
    }
    if body.Email == "" || body.Password == "" {
        writeError(w, http.StatusBadRequest, "email and password are required"); return
    }
    var user models.User
    if err := h.db.Where("email = ?", body.Email).First(&user).Error; err != nil {
        writeError(w, http.StatusUnauthorized, "invalid email or password"); return
    }
    if err := CheckPassword(body.Password, user.PasswordHash); err != nil {
        writeError(w, http.StatusUnauthorized, "invalid email or password"); return
    }
    if !user.EmailVerified {
        writeError(w, http.StatusForbidden, "EMAIL_NOT_VERIFIED"); return
    }
    tok, err := IssueToken(user.ID.String(), user.Email)
    if err != nil {
        writeServerError(w, err); return
    }
    writeJSON(w, http.StatusOK, map[string]any{
        "userId": user.ID.String(), "email": user.Email, "name": user.Name,
        "emailVerified": user.EmailVerified, "token": tok,
    })
}

// GET /v1/auth/me  (requires RequireAuth)
func (h *Handler) Me(w http.ResponseWriter, r *http.Request) {
    claims := middleware.UserFromCtx(r.Context())
    if claims == nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    var user models.User
    if err := h.db.Where("id = ?", claims.UserID).First(&user).Error; err != nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    writeJSON(w, http.StatusOK, map[string]any{
        "userId": user.ID.String(), "email": user.Email, "name": user.Name,
        "emailVerified": user.EmailVerified,
    })
}

// GET /v1/auth/verify-email?token=
// Returns JSON (not redirect) — Server Action handles the redirect on the frontend.
func (h *Handler) VerifyEmail(w http.ResponseWriter, r *http.Request) {
    rawToken := r.URL.Query().Get("token")
    if rawToken == "" {
        writeError(w, http.StatusBadRequest, "INVALID_OR_EXPIRED_TOKEN"); return
    }
    th := hashToken(rawToken)
    var ev models.EmailVerification
    if err := h.db.Where("token_hash = ?", th).First(&ev).Error; err != nil ||
        ev.UsedAt != nil || time.Now().After(ev.ExpiresAt) {
        writeError(w, http.StatusBadRequest, "INVALID_OR_EXPIRED_TOKEN"); return
    }
    now := time.Now()
    h.db.Model(&ev).Update("used_at", &now)
    h.db.Model(&models.User{}).Where("id = ?", ev.UserID).
        Updates(map[string]any{"email_verified": true, "email_verified_at": &now})
    writeJSON(w, http.StatusOK, map[string]bool{"verified": true})
}

// POST /v1/auth/resend-verification  (requires RequireAuth)
func (h *Handler) ResendVerification(w http.ResponseWriter, r *http.Request) {
    claims := middleware.UserFromCtx(r.Context())
    if claims == nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    var cnt int64
    h.db.Model(&models.EmailVerification{}).
        Where("user_id = ? AND created_at > ?", claims.UserID, time.Now().Add(-time.Hour)).
        Count(&cnt)
    if cnt >= 3 {
        writeError(w, http.StatusTooManyRequests, "Too many requests"); return
    }
    h.db.Where("user_id = ? AND used_at IS NULL", claims.UserID).Delete(&models.EmailVerification{})
    rawToken, tokenHash := GenerateToken()
    ev := models.EmailVerification{
        TokenHash: tokenHash,
        ExpiresAt: time.Now().Add(24 * time.Hour),
    }
    // set UserID from UUID string
    h.db.Where("id = ?", claims.UserID).First(&models.User{})
    h.db.Exec("INSERT INTO email_verifications (user_id, token_hash, expires_at) VALUES (?, ?, ?)",
        claims.UserID, tokenHash, ev.ExpiresAt)
    var user models.User
    h.db.Where("id = ?", claims.UserID).First(&user)
    verifyURL := os.Getenv("NEXT_PUBLIC_APP_URL") + "/verify-email?token=" + rawToken
    go h.email.SendVerificationEmail(user.Email, user.Name, verifyURL)
    writeJSON(w, http.StatusOK, map[string]bool{"sent": true})
}

// POST /v1/auth/forgot-password
func (h *Handler) ForgotPassword(w http.ResponseWriter, r *http.Request) {
    var body struct{ Email string `json:"email"` }
    json.NewDecoder(r.Body).Decode(&body)
    var user models.User
    if err := h.db.Where("email = ?", body.Email).First(&user).Error; err != nil {
        writeJSON(w, http.StatusOK, map[string]bool{"sent": true}); return
    }
    var cnt int64
    h.db.Model(&models.PasswordResetToken{}).
        Where("user_id = ? AND created_at > ?", user.ID, time.Now().Add(-time.Hour)).Count(&cnt)
    if cnt < 3 {
        h.db.Where("user_id = ?", user.ID).Delete(&models.PasswordResetToken{})
        rawToken, tokenHash := GenerateToken()
        h.db.Create(&models.PasswordResetToken{
            UserID: user.ID, TokenHash: tokenHash, ExpiresAt: time.Now().Add(time.Hour),
        })
        resetURL := os.Getenv("NEXT_PUBLIC_APP_URL") + "/reset-password?token=" + rawToken
        go h.email.SendPasswordResetEmail(user.Email, user.Name, resetURL)
    }
    writeJSON(w, http.StatusOK, map[string]bool{"sent": true})
}

// GET /v1/auth/validate-reset-token?token=
func (h *Handler) ValidateResetToken(w http.ResponseWriter, r *http.Request) {
    rawToken := r.URL.Query().Get("token")
    if rawToken == "" {
        writeError(w, http.StatusBadRequest, "INVALID_OR_EXPIRED_TOKEN"); return
    }
    th := hashToken(rawToken)
    var tok models.PasswordResetToken
    if err := h.db.Where("token_hash = ? AND used_at IS NULL AND expires_at > ?", th, time.Now()).
        First(&tok).Error; err != nil {
        writeError(w, http.StatusBadRequest, "INVALID_OR_EXPIRED_TOKEN"); return
    }
    writeJSON(w, http.StatusOK, map[string]bool{"valid": true})
}

// POST /v1/auth/reset-password
func (h *Handler) ResetPassword(w http.ResponseWriter, r *http.Request) {
    var body struct {
        Token       string `json:"token"`
        NewPassword string `json:"newPassword"`
    }
    if err := json.NewDecoder(r.Body).Decode(&body); err != nil {
        writeError(w, http.StatusBadRequest, "invalid request body"); return
    }
    if body.Token == "" || body.NewPassword == "" {
        writeError(w, http.StatusBadRequest, "token and newPassword are required"); return
    }
    if len(body.NewPassword) < 8 {
        writeError(w, http.StatusBadRequest, "password must be at least 8 characters"); return
    }
    th := hashToken(body.Token)
    var tok models.PasswordResetToken
    if err := h.db.Where("token_hash = ? AND used_at IS NULL AND expires_at > ?", th, time.Now()).
        First(&tok).Error; err != nil {
        writeError(w, http.StatusBadRequest, "INVALID_OR_EXPIRED_TOKEN"); return
    }
    hash, err := HashPassword(body.NewPassword)
    if err != nil {
        writeServerError(w, err); return
    }
    h.db.Model(&models.User{}).Where("id = ?", tok.UserID).Update("password_hash", hash)
    now := time.Now()
    h.db.Model(&tok).Update("used_at", &now)
    writeJSON(w, http.StatusOK, map[string]bool{"success": true})
}
```

