func TestIssueToken_IsPlainJWT(t *testing.T) {
    tok, err := auth.IssueToken("user-id", "a@b.com")
    if err != nil {
        t.Fatal(err)
    }
    // Plain JWT has 3 base64 segments separated by dots
    parts := strings.Split(tok, ".")
    if len(parts) != 3 {
        t.Fatalf("expected plain JWT (3 parts), got %d parts: %s", len(parts), tok)
    }
}

func TestValidateToken_RoundTrip(t *testing.T) {
    tok, _ := auth.IssueToken("user-id", "a@b.com")
    claims, err := auth.ValidateToken(tok)
    if err != nil {
        t.Fatal(err)
    }
    if claims.UserID != "user-id" {
        t.Fatalf("userID = %q, want %q", claims.UserID, "user-id")
    }
    if claims.Email != "a@b.com" {
        t.Fatalf("email = %q, want %q", claims.Email, "a@b.com")
    }
}

func TestGenerateToken_LengthAndDistinct(t *testing.T) {
    raw, hash := auth.GenerateToken()
    if len(raw) != 64 {
        t.Fatalf("rawToken length %d, want 64", len(raw))
    }
    if raw == hash {
        t.Fatal("rawToken and tokenHash must differ")
    }
}

func TestHashPassword_RoundTrip(t *testing.T) {
    h, err := auth.HashPassword("secret123")
    if err != nil {
        t.Fatal(err)
    }
    if err := auth.CheckPassword("secret123", h); err != nil {
        t.Fatal("valid password rejected:", err)
    }
    if err := auth.CheckPassword("wrong", h); err == nil {
        t.Fatal("wrong password accepted")
    }
}
