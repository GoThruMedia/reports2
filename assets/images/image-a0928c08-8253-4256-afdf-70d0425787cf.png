## Task 5: Auth Middleware — Bearer Token

**Files:**
- Create: `internal/middleware/auth.go`
- Create: `internal/middleware/auth_test.go`

**Interfaces:**
- Consumes: `auth.ValidateToken`, `auth.Claims`
- Produces:
  - `middleware.RequireAuth(next http.Handler) http.Handler`
  - `middleware.UserFromCtx(ctx context.Context) *auth.Claims`

Reads `Authorization: Bearer <token>` header — no cookie dependency. All callers are Next.js Server Actions running on the server.

- [ ] **Step 1: Write failing tests**

Create `internal/middleware/auth_test.go`:

```go
package middleware_test

import (
    "net/http"
    "net/http/httptest"
    "os"
    "testing"

    "gothru-3d-api/internal/auth"
    "gothru-3d-api/internal/middleware"
)

func init() {
    os.Setenv("GOTHRU_3D_JWT_SECRET", "test-secret-at-least-32-chars-ok!")
}

func TestRequireAuth_NoHeader_Returns401(t *testing.T) {
    handler := middleware.RequireAuth(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        w.WriteHeader(http.StatusOK)
    }))
    req := httptest.NewRequest(http.MethodGet, "/", nil)
    rr := httptest.NewRecorder()
    handler.ServeHTTP(rr, req)
    if rr.Code != http.StatusUnauthorized {
        t.Fatalf("got %d, want 401", rr.Code)
    }
}

func TestRequireAuth_ValidBearer_InjectsUserID(t *testing.T) {
    tok, _ := auth.IssueToken("uid-123", "a@b.com")
    var gotUserID string
    handler := middleware.RequireAuth(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        claims := middleware.UserFromCtx(r.Context())
        if claims != nil {
            gotUserID = claims.UserID
        }
        w.WriteHeader(http.StatusOK)
    }))
    req := httptest.NewRequest(http.MethodGet, "/", nil)
    req.Header.Set("Authorization", "Bearer "+tok)
    rr := httptest.NewRecorder()
    handler.ServeHTTP(rr, req)
    if rr.Code != http.StatusOK {
        t.Fatalf("got %d, want 200", rr.Code)
    }
    if gotUserID != "uid-123" {
        t.Fatalf("userID = %q, want %q", gotUserID, "uid-123")
    }
}

func TestRequireAuth_InvalidToken_Returns401(t *testing.T) {
    handler := middleware.RequireAuth(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        w.WriteHeader(http.StatusOK)
    }))
    req := httptest.NewRequest(http.MethodGet, "/", nil)
    req.Header.Set("Authorization", "Bearer not-a-real-jwt")
    rr := httptest.NewRecorder()
    handler.ServeHTTP(rr, req)
    if rr.Code != http.StatusUnauthorized {
        t.Fatalf("got %d, want 401", rr.Code)
    }
}
