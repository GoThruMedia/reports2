- [ ] **Step 3: Create `internal/billing/handler.go`**

```go
package billing

import (
    "encoding/json"
    "net/http"
    "os"
    "time"

    "github.com/stripe/stripe-go/v76"
    checkoutsession "github.com/stripe/stripe-go/v76/checkout/session"
    portalsession "github.com/stripe/stripe-go/v76/billingportal/session"
    stripecustomer "github.com/stripe/stripe-go/v76/customer"
    "gorm.io/gorm"

    "gothru-3d-api/internal/apierror"
    "gothru-3d-api/internal/middleware"
    "gothru-3d-api/internal/models"
)

type Handler struct{ db *gorm.DB }

func NewHandler(db *gorm.DB) *Handler {
    stripe.Key = os.Getenv("STRIPE_SECRET_KEY")
    return &Handler{db: db}
}

func writeJSON(w http.ResponseWriter, status int, v any) {
    w.Header().Set("Content-Type", "application/json")
    w.WriteHeader(status)
    json.NewEncoder(w).Encode(v)
}

func writeError(w http.ResponseWriter, status int, msg string) {
    writeJSON(w, status, map[string]string{"error": msg})
}

func writeServerError(w http.ResponseWriter, err error) {
    writeError(w, http.StatusInternalServerError, apierror.Sanitize(err))
}

// POST /v1/billing/checkout — get or create Stripe Customer, return Checkout Session URL
func (h *Handler) CreateCheckout(w http.ResponseWriter, r *http.Request) {
    claims := middleware.UserFromCtx(r.Context())
    if claims == nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    customerID, err := h.getOrCreateCustomer(claims.UserID)
    if err != nil {
        writeServerError(w, err); return
    }
    appURL := os.Getenv("NEXT_PUBLIC_APP_URL")
    params := &stripe.CheckoutSessionParams{
        Customer: stripe.String(customerID),
        Mode:     stripe.String(string(stripe.CheckoutSessionModeSubscription)),
        LineItems: []*stripe.CheckoutSessionLineItemParams{
            {Price: stripe.String(os.Getenv("STRIPE_PRICE_ID")), Quantity: stripe.Int64(1)},
        },
        SuccessURL: stripe.String(appURL + "/billing/success?session_id={CHECKOUT_SESSION_ID}"),
        CancelURL:  stripe.String(appURL + "/billing/cancel"),
    }
    s, err := checkoutsession.New(params)
    if err != nil {
        writeServerError(w, err); return
    }
    writeJSON(w, http.StatusOK, map[string]string{"url": s.URL})
}

// POST /v1/billing/portal — open Stripe Billing Portal for existing customer
func (h *Handler) CreatePortal(w http.ResponseWriter, r *http.Request) {
    claims := middleware.UserFromCtx(r.Context())
    if claims == nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    var sub models.Subscription
    if err := h.db.Where("user_id = ?", claims.UserID).First(&sub).Error; err != nil {
        writeError(w, http.StatusBadRequest, "no subscription record found"); return
    }
    params := &stripe.BillingPortalSessionParams{
        Customer:  stripe.String(sub.StripeCustomerID),
        ReturnURL: stripe.String(os.Getenv("NEXT_PUBLIC_APP_URL") + "/billing"),
    }
    s, err := portalsession.New(params)
    if err != nil {
        writeServerError(w, err); return
    }
    writeJSON(w, http.StatusOK, map[string]string{"url": s.URL})
}

// GET /v1/billing/status — return subscription status for the signed-in user
func (h *Handler) GetStatus(w http.ResponseWriter, r *http.Request) {
    claims := middleware.UserFromCtx(r.Context())
    if claims == nil {
        writeError(w, http.StatusUnauthorized, "Unauthorized"); return
    }
    var sub models.Subscription
    if err := h.db.Where("user_id = ?", claims.UserID).First(&sub).Error; err != nil {
        writeJSON(w, http.StatusOK, map[string]any{"status": "inactive", "currentPeriodEnd": nil})
        return
    }
    var periodEnd interface{} = nil
    if sub.CurrentPeriodEnd != nil {
        periodEnd = sub.CurrentPeriodEnd.Format(time.RFC3339)
    }
    writeJSON(w, http.StatusOK, map[string]any{
        "status": sub.Status, "currentPeriodEnd": periodEnd,
    })
}

func (h *Handler) getOrCreateCustomer(userID string) (string, error) {
    var sub models.Subscription
    if err := h.db.Where("user_id = ?", userID).First(&sub).Error; err == nil {
        return sub.StripeCustomerID, nil
    }
    var user models.User
    if err := h.db.Where("id = ?", userID).First(&user).Error; err != nil {
        return "", err
    }
    c, err := stripecustomer.New(&stripe.CustomerParams{Email: stripe.String(user.Email)})
    if err != nil {
        return "", err
    }
    h.db.Create(&models.Subscription{
        UserID:           models.MustParseUUID(userID),
        StripeCustomerID: c.ID,
        Status:           "inactive",
    })
    return c.ID, nil
}
```

