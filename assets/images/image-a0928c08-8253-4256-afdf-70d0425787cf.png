- [ ] **Step 3: Create `internal/billing/webhook.go`**

```go
package billing

import (
    "encoding/json"
    "io"
    "net/http"
    "os"
    "time"

    "github.com/stripe/stripe-go/v76"
    "github.com/stripe/stripe-go/v76/webhook"
    "gothru-3d-api/internal/models"
)

// POST /v1/billing/webhook — no RequireAuth; Stripe-Signature header is proof of authenticity
func (h *Handler) HandleWebhook(w http.ResponseWriter, r *http.Request) {
    payload, err := io.ReadAll(r.Body)
    if err != nil {
        w.WriteHeader(http.StatusBadRequest); return
    }
    sig := r.Header.Get("Stripe-Signature")
    event, err := webhook.ConstructEvent(payload, sig, os.Getenv("STRIPE_WEBHOOK_SECRET"))
    if err != nil {
        w.WriteHeader(http.StatusBadRequest); return
    }
    switch event.Type {
    case "customer.subscription.created", "customer.subscription.updated":
        var sub stripe.Subscription
        if err := json.Unmarshal(event.Data.Raw, &sub); err != nil {
            w.WriteHeader(http.StatusBadRequest); return
        }
        periodEnd := time.Unix(sub.CurrentPeriodEnd, 0)
        h.db.Model(&models.Subscription{}).
            Where("stripe_customer_id = ?", sub.Customer.ID).
            Updates(map[string]any{
                "stripe_subscription_id": sub.ID,
                "status":                 string(sub.Status),
                "current_period_end":     &periodEnd,
            })
    case "customer.subscription.deleted":
        var sub stripe.Subscription
        if err := json.Unmarshal(event.Data.Raw, &sub); err != nil {
            w.WriteHeader(http.StatusBadRequest); return
        }
        h.db.Model(&models.Subscription{}).
            Where("stripe_customer_id = ?", sub.Customer.ID).
            Updates(map[string]any{
                "status":                 "canceled",
                "stripe_subscription_id": sub.ID,
            })
    }
    w.WriteHeader(http.StatusOK)
}
```

