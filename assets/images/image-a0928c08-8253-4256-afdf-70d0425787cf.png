## Task 18: Main Server + Wire Everything

**Files:**
- Create: `cmd/server/main.go`

- [ ] **Step 1: Create `cmd/server/main.go`**

```go
package main

import (
    "fmt"
    "log"
    "net/http"
    "os"

    "github.com/go-chi/chi/v5"
    chiMiddleware "github.com/go-chi/chi/v5/middleware"
    "github.com/rs/cors"

    "gothru-3d-api/internal/auth"
    "gothru-3d-api/internal/db"
    "gothru-3d-api/internal/email"
    appMiddleware "gothru-3d-api/internal/middleware"
    "gothru-3d-api/internal/projects"
)

func main() {
    gormDB, err := db.Connect(os.Getenv("DATABASE_URL"))
    if err != nil {
        log.Fatal("db:", err)
    }

    emailSvc := email.NewService()
    authHandler := auth.NewHandler(gormDB, emailSvc)
    projectHandler := projects.NewHandler(gormDB)

    allowedOrigin := os.Getenv("CORS_ALLOWED_ORIGIN")
    if allowedOrigin == "" {
        allowedOrigin = "http://localhost:3000"
    }
    corsMiddleware := cors.New(cors.Options{
        AllowedOrigins:   []string{allowedOrigin},
        AllowedMethods:   []string{http.MethodGet, http.MethodPost, http.MethodPatch, http.MethodDelete, http.MethodOptions},
        AllowedHeaders:   []string{"Authorization", "Content-Type"},
        AllowCredentials: false,
    })

    r := chi.NewRouter()
    r.Use(corsMiddleware.Handler)
    r.Use(chiMiddleware.Logger)
    r.Use(chiMiddleware.Recoverer)

    r.Route("/v1/auth", func(r chi.Router) {
        r.Post("/register", authHandler.Register)
        r.Post("/login", authHandler.Login)
        r.Get("/verify-email", authHandler.VerifyEmail)
        r.Post("/forgot-password", authHandler.ForgotPassword)
        r.Get("/validate-reset-token", authHandler.ValidateResetToken)
        r.Post("/reset-password", authHandler.ResetPassword)
        r.Group(func(r chi.Router) {
            r.Use(appMiddleware.RequireAuth)
            r.Get("/me", authHandler.Me)
            r.Post("/resend-verification", authHandler.ResendVerification)
        })
    })

    r.Group(func(r chi.Router) {
        r.Use(appMiddleware.RequireAuth)
        r.Get("/v1/projects", projectHandler.List)
        r.Post("/v1/projects", projectHandler.Create)
        r.Get("/v1/projects/{id}", projectHandler.Get)
        r.Patch("/v1/projects/{id}", projectHandler.Update)
        r.Delete("/v1/projects/{id}", projectHandler.Delete)
        r.Post("/v1/projects/{id}/publish", projectHandler.Publish)
        r.Post("/v1/projects/{id}/unpublish", projectHandler.Unpublish)
        r.Post("/v1/upload", projectHandler.Upload)
        r.Get("/v1/files", projectHandler.ServeFile)
        r.Delete("/v1/files", projectHandler.DeleteFile)
        r.Post("/v1/reset", projectHandler.ResetProject)
    })

    r.Get("/health", func(w http.ResponseWriter, r *http.Request) {
        w.WriteHeader(http.StatusOK)
        fmt.Fprintln(w, "ok")
    })

    port := os.Getenv("PORT")
    if port == "" { port = "8080" }
    fmt.Printf("gothru-3d-api listening on :%s\n", port)
    log.Fatal(http.ListenAndServe(":"+port, r))
}
```

