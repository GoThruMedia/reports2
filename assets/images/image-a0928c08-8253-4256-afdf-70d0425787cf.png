package models

import (
    "time"

    "github.com/google/uuid"
)

type User struct {
    ID                    uuid.UUID  `gorm:"type:uuid;default:gen_random_uuid();primaryKey"`
    Email                 string     `gorm:"uniqueIndex;not null"`
    PasswordHash          string     `gorm:"not null"`
    Name                  string     `gorm:"not null"`
    EmailVerified         bool       `gorm:"default:false"`
    EmailVerifiedAt       *time.Time
    GothruDashboardUserID *string
    GothruDashboardEmail  *string
    Projects              []Project  `gorm:"foreignKey:UserID"`
    CreatedAt             time.Time
    UpdatedAt             time.Time
}

type Project struct {
    ID              uuid.UUID     `gorm:"type:uuid;default:gen_random_uuid();primaryKey"`
    UserID          uuid.UUID     `gorm:"type:uuid;not null;index"`
    Name            string        `gorm:"default:'Untitled Project'"`
    LocationAddress *string
    LocationLat     *float64
    LocationLng     *float64
    FloorConfigs    *string       `gorm:"type:jsonb"`
    GeneratedTwin   *string       `gorm:"type:jsonb"`
    CanvasData      *string       `gorm:"type:jsonb"`
    Status          string        `gorm:"default:'draft'"`
    PublishedAt     *time.Time
    Files           []ProjectFile `gorm:"foreignKey:ProjectID"`
    CreatedAt       time.Time
    UpdatedAt       time.Time
}

type ProjectFile struct {
    ID           uuid.UUID `gorm:"type:uuid;default:gen_random_uuid();primaryKey"`
    ProjectID    uuid.UUID `gorm:"type:uuid;not null;index"`
    UserID       uuid.UUID `gorm:"type:uuid;not null"`
    OriginalName string    `gorm:"not null"`
    FilePath     string    `gorm:"not null"`
    FloorIndex   *int
    FileSize     *int64
