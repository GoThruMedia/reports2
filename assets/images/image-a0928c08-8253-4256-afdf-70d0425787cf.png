## Task 4: Email Service (Plunk Track Events)

**Files:**
- Create: `internal/email/service.go`

**Interfaces:**
- Consumes: `PLUNK_API_KEY`, `PLUNK_VERIFY_EVENT`, `PLUNK_RESET_EVENT` env vars
- Produces:
  - `email.NewService() *email.Service`
  - `(s *Service) SendVerificationEmail(to, name, verifyURL string) error`
  - `(s *Service) SendPasswordResetEmail(to, name, resetURL string) error`

Uses Plunk's `POST /v1/track` endpoint. The event name acts as the template ID — create the corresponding automation in the Plunk dashboard with variables `{{name}}` and `{{verifyURL}}` (or `{{resetURL}}`).

- [ ] **Step 1: Create `internal/email/service.go`**

```go
package email

import (
    "bytes"
    "encoding/json"
    "fmt"
    "net/http"
    "os"
)

type Service struct {
    apiKey      string
    verifyEvent string
    resetEvent  string
}

func NewService() *Service {
    return &Service{
        apiKey:      os.Getenv("PLUNK_API_KEY"),
        verifyEvent: os.Getenv("PLUNK_VERIFY_EVENT"),
        resetEvent:  os.Getenv("PLUNK_RESET_EVENT"),
    }
}

type plunkTrackRequest struct {
    Event      string            `json:"event"`
    Email      string            `json:"email"`
    Data       map[string]string `json:"data,omitempty"`
    Subscribed bool              `json:"subscribed"`
}

func (s *Service) track(email, event string, data map[string]string) error {
    payload := plunkTrackRequest{
        Event:      event,
        Email:      email,
        Data:       data,
        Subscribed: false,
    }
    body, err := json.Marshal(payload)
    if err != nil {
        return fmt.Errorf("marshal plunk payload: %w", err)
    }
    req, err := http.NewRequest(http.MethodPost, "https://api.useplunk.com/v1/track", bytes.NewReader(body))
    if err != nil {
        return fmt.Errorf("create plunk request: %w", err)
    }
    req.Header.Set("Content-Type", "application/json")
    req.Header.Set("Authorization", "Bearer "+s.apiKey)
    resp, err := http.DefaultClient.Do(req)
    if err != nil {
        return fmt.Errorf("plunk track: %w", err)
    }
    defer resp.Body.Close()
    if resp.StatusCode >= 400 {
        return fmt.Errorf("plunk returned status %d", resp.StatusCode)
    }
    return nil
}

func (s *Service) SendVerificationEmail(to, name, verifyURL string) error {
    return s.track(to, s.verifyEvent, map[string]string{
        "name":      name,
        "verifyURL": verifyURL,
    })
}

func (s *Service) SendPasswordResetEmail(to, name, resetURL string) error {
    return s.track(to, s.resetEvent, map[string]string{
        "name":     name,
        "resetURL": resetURL,
    })
}
```

